# ============================================================================
#  Your launchpad — environment variables
# ============================================================================
# You only need TWO of these. Everything about the network (which chain, the
# contracts, the shared coin feed) is already built in, so a fresh deploy works
# with nothing but the two required values below.
#
# On Vercel you do not edit this file — you paste these into the deploy form, or
# into Project → Settings → Environment Variables. Copy this file to .env.local
# only if you are running it on your own machine.

# ---- REQUIRED ----

# Your design: brand, colours, type, copy — one value, generated for you by the
# "Create your launchpad" designer. Paste the whole thing. Do not hand-edit it;
# regenerate it in the designer if you want to change something.
LAUNCHPAD_CONFIG=

# Lets people upload images for their coins. Free key at https://pinata.cloud
# (create a key, copy the JWT). Without it, coin creation fails.
PINATA_JWT=

# ---- OPTIONAL ----

# Your real address, once you know it (e.g. https://moonshot.vercel.app or your
# own domain). Fixes your Google links, sitemap and share cards to point at you.
# Safe to add later — it is the one value you can change on its own.
# NEXT_PUBLIC_SITE_URL=

# Enables phone wallets (WalletConnect). Free at https://cloud.reown.com
# Without it, browser-extension wallets still work; only mobile wallets need it.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---- ADVANCED (you should not need these) ----
# The network is baked into the build (see next.config.mjs). Set any of these
# ONLY to point this launchpad at a different chain or a launchpad of your own.
# NEXT_PUBLIC_CHAIN_ID=
# NEXT_PUBLIC_RPC_URL=
# NEXT_PUBLIC_FACTORY_ADDRESS=
# NEXT_PUBLIC_FEE_MANAGER_ADDRESS=
# NEXT_PUBLIC_INDEXER_URL=
